<!-- Plugin Configuration File:
https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
     <!-- Unique identifier of the plugin. It should be FQN, cannot be changed between the plugin
     versions. -->
     <id>com.allseas.go-text-template</id>

     <!-- Public plugin name should be written in Title Case.
         Guidelines:
     https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
     <name>Go-Text-Template</name>

     <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->


     <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines:
     https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
     <description>Language support for go text/template package</description>
     <vendor />

     <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
     <depends>com.intellij.modules.lsp</depends>
     <depends>com.redhat.devtools.lsp4ij</depends>

     <depends>com.intellij.modules.json</depends>
     <depends>com.intellij.properties</depends>
     <depends>com.intellij.modules.lang</depends>
     <depends>org.jetbrains.plugins.textmate</depends>
     <resource-bundle>messages.MyMessageBundle</resource-bundle>
     <!-- Extensions defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
     <extensions defaultExtensionNs="com.intellij">
          <toolWindow id="MyToolWindow"
               factoryClass="com.allseas.gotexttemplate.MyToolWindowFactory"
               icon="AllIcons.Toolwindows.ToolWindowPalette" />
          <textmate.bundleProvider
               implementation="com.allseas.gotexttemplate.TemplateTextMateBundleProvider" />

          <defaultLiveTemplates file="liveTemplates/GoTemplate.xml" />
          <liveTemplateContext
               contextId="GOTMPL"
               implementation="com.allseas.gotexttemplate.GoTextTemplateContext" />

          <fileType
               name="Go Template"
               implementationClass="com.allseas.gotexttemplate.TmplFileType"
               fieldName="INSTANCE"
               language="GoTemplate"
               extensions=".tmpl" />

          <applicationService
               serviceImplementation="com.allseas.gotexttemplate.AppSettings" />
          <projectService
               serviceImplementation="com.allseas.gotexttemplate.ProjectSettings" />
          <applicationConfigurable
               parentId="tools"
               instance="com.allseas.gotexttemplate.AppSettingsConfigurable"
               id="com.allseas.gotexttemplate.AppSettingsConfigurable"
               displayName="Go Text Template Support" />
          <projectConfigurable
               parentId="com.allseas.gotexttemplate.AppSettingsConfigurable"
               instance="com.allseas.gotexttemplate.ProjectSettingsConfigurable"
               id="com.allseas.gotexttemplate.ProjectSettingsConfigurable"
               displayName="Project Settings" />
     </extensions>

     <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">
          <server factoryClass="com.allseas.gotexttemplate.TextTemplateLspServerFactory"
               id="go-text-template-lsp" />

          <fileNamePatternMapping patterns="*.tmpl" serverId="go-text-template-lsp" />
     </extensions>

</idea-plugin>