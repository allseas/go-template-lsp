  <template name="wblock" value="{{ block &quot;$VAR1$&quot; $VAR2$ }}$SELECTION${{ end }}" description="Wrap with block." toReformat="true" toShortenFQNames="true">
    <variable name="VAR1" expression="" defaultValue="" alwaysStopAt="true" />
    <variable name="VAR2" expression="" defaultValue="" alwaysStopAt="true" />
    <context>
      <option name="GOTMPL" value="true" />
    </context>
  </template>
</templateSet>
