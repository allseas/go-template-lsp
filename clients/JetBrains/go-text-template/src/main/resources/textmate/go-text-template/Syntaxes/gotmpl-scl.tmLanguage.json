{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "fileTypes": ["scl.tmpl", "scl.gotmpl"],
    "injections": {
        "L:source.gotmpl.scl - meta.embedded.gotmpl - comment.block.gotmpl": {
            "patterns": [
                { "include": "source.gotmpl#comment" },
                { "include": "source.gotmpl#action" }
            ]
        }
    },
    "patterns": [{ "include": "source.scl" }],
    "scopeName": "source.gotmpl.scl"
}
