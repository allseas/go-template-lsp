{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "fileTypes": ["tmpl", "gotmpl"],
    "patterns": [{ "include": "#comment" }, { "include": "#action" }],
    "repository": {
        "action": {
            "begin": "\\{\\{\\-?",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.embedded.begin.gotmpl" }
            },
            "end": "\\-?\\}\\}",
            "endCaptures": {
                "0": { "name": "punctuation.definition.embedded.end.gotmpl" }
            },
            "name": "meta.embedded.gotmpl",
            "patterns": [
                { "include": "#keyword" },
                { "include": "#pipe" },
                { "include": "#comma" },
                { "include": "#template-name" },
                { "include": "#variable-declaration" },
                { "include": "#variable-assignment" },
                { "include": "#boolean" },
                { "include": "#number" },
                { "include": "#string-double" },
                { "include": "#string-raw" },
                { "include": "#char" },
                { "include": "#nil" },
                { "include": "#dot" },
                { "include": "#field" },
                { "include": "#parentheses" },
                { "include": "#variable" },
                { "include": "#builtin" }
            ]
        },
        "boolean": {
            "match": "\\b(true|false)\\b",
            "name": "constant.language.boolean.gotmpl"
        },
        "builtin": {
            "match": "\\b(and|call|html|index|slice|js|len|not|or|print|printf|println|urlquery|eq|ne|lt|le|gt|ge)\\b",
            "name": "support.function.gotmpl"
        },
        "char": {
            "match": "'(?:\\\\(?:[abfnrtv\\\\\"']|x[0-9A-Fa-f]{2}|[0-7]{3}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8})|[^'\\\\])'",
            "name": "string.quoted.single.gotmpl"
        },
        "comma": { "match": ",", "name": "punctuation.separator.comma.gotmpl" },
        "comment": {
            "begin": "\\{\\{(?:-\\s)?/\\*",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.comment.begin.gotmpl" }
            },
            "end": "\\*/(?:\\s-)?\\}\\}",
            "endCaptures": {
                "0": { "name": "punctuation.definition.comment.end.gotmpl" }
            },
            "name": "comment.block.gotmpl"
        },
        "dot": {
            "match": "(?<![a-zA-Z_\\w])\\.(?![a-zA-Z_\\w])",
            "name": "variable.language.dot.gotmpl"
        },
        "field": {
            "match": "\\.[a-zA-Z_]\\w*",
            "name": "variable.other.member.gotmpl"
        },
        "keyword": {
            "match": "\\b(if|else|end|range|with|template|block|define|break|continue)\\b",
            "name": "keyword.control.gotmpl"
        },
        "nil": { "match": "\\bnil\\b", "name": "constant.language.nil.gotmpl" },
        "number": {
            "match": "\\b(?:(?:0[xX](?:_?[0-9A-Fa-f](?:_?[0-9A-Fa-f])*(?:\\.(?:[0-9A-Fa-f](?:_?[0-9A-Fa-f])*)?)?|\\.[0-9A-Fa-f](?:_?[0-9A-Fa-f])*)[pP][-+]?[0-9](?:_?[0-9])*|[0-9](?:_?[0-9])*(?:\\.(?:[0-9](?:_?[0-9])*)?(?:[eE][-+]?[0-9](?:_?[0-9])*)?|[eE][-+]?[0-9](?:_?[0-9])*))|(?:0[xX]_?[0-9A-Fa-f](?:_?[0-9A-Fa-f])*|0[bB]_?[01](?:_?[01])*|0[oO]?_?[0-7](?:_?[0-7])*|(?:0|[1-9](?:_?[0-9](?:_?[0-9])*)?)))i?\\b",
            "name": "constant.numeric.gotmpl"
        },
        "parentheses": {
            "begin": "\\(",
            "beginCaptures": {
                "0": { "name": "punctuation.section.parens.begin.gotmpl" }
            },
            "end": "\\)",
            "endCaptures": {
                "0": { "name": "punctuation.section.parens.end.gotmpl" }
            },
            "patterns": [
                { "include": "#keyword" },
                { "include": "#pipe" },
                { "include": "#comma" },
                { "include": "#template-name" },
                { "include": "#variable-declaration" },
                { "include": "#variable-assignment" },
                { "include": "#boolean" },
                { "include": "#number" },
                { "include": "#string-double" },
                { "include": "#string-raw" },
                { "include": "#char" },
                { "include": "#nil" },
                { "include": "#dot" },
                { "include": "#field" },
                { "include": "#parentheses" },
                { "include": "#variable" },
                { "include": "#builtin" }
            ]
        },
        "pipe": { "match": "\\|", "name": "keyword.operator.pipe.gotmpl" },
        "string-double": {
            "begin": "\"",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.string.begin.gotmpl" }
            },
            "end": "\"",
            "endCaptures": {
                "0": { "name": "punctuation.definition.string.end.gotmpl" }
            },
            "name": "string.quoted.double.gotmpl",
            "patterns": [
                {
                    "match": "\\\\(?:[abfnrtv\\\\\"']|x[0-9A-Fa-f]{2}|[0-7]{3}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8})",
                    "name": "constant.character.escape.gotmpl"
                }
            ]
        },
        "string-raw": {
            "begin": "`",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.string.begin.gotmpl" }
            },
            "end": "`",
            "endCaptures": {
                "0": { "name": "punctuation.definition.string.end.gotmpl" }
            },
            "name": "string.quoted.other.raw.gotmpl"
        },
        "template-name": {
            "captures": { "1": { "name": "entity.name.function.gotmpl" } },
            "match": "(?<=template|block|define)\\s+(\"[^\"]*\")"
        },
        "variable": {
            "match": "\\$[a-zA-Z_]\\w*|\\$",
            "name": "variable.other.gotmpl"
        },
        "variable-assignment": {
            "captures": {
                "1": { "name": "variable.other.gotmpl" },
                "2": { "name": "keyword.operator.assignment.gotmpl" }
            },
            "match": "(\\$[a-zA-Z_]\\w*)\\s*(=)"
        },
        "variable-declaration": {
            "captures": {
                "1": { "name": "variable.other.gotmpl" },
                "2": { "name": "keyword.operator.assignment.gotmpl" }
            },
            "match": "(\\$[a-zA-Z_]\\w*)\\s*(:=)"
        }
    },
    "scopeName": "source.gotmpl"
}
