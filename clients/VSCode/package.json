{
  "name": "text-template-support",
  "displayName": "text/template Support",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "gotmpl",
      "aliases": ["Go text/template", "gotmpl"],
      "extensions": [".templ",".tmpl"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "gotmpl",
      "scopeName": "source.gotmpl",
      "path": "./syntaxes/gotmpl.tmLanguage.json"
    }]
  }
}
