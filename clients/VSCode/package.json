{
    "name": "text-template-support",
    "displayName": "text/template Support",
    "description": "",
    "version": "0.1.0",
    "engines": {
        "vscode": "^1.116.0"
    },
    "repository": {
        "url": "",
        "directory": "",
        "type": ""
    },
    "categories": [
        "Programming Languages"
    ],
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "check-types": "tsc --noEmit",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "lint:fix": "npx eslint . --fix",
        "lint:check": "npx eslint .",
        "format:fix": "npx prettier --write .",
        "format:check": "npx prettier --check .",
        "test": "npm run compile && ts-node --esm ../../scripts/build-server-binaries.ts && shx mkdir -p out/server/bin && shx cp ../../dist/server/* out/server/bin/ && vscode-test",
        "verify": "npm run lint:check && npm run format:check && npm test",
        "package": "npm run verify && node esbuild.js --production && vsce package --no-dependencies && shx mv *.vsix ../../",
        "package:no-verify": "node esbuild.js --production && vsce package --no-dependencies && shx mv *.vsix ../../"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "@types/vscode": "^1.116.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.9.1",
        "esbuild": "^0.28.0",
        "eslint": "^10.2.1",
        "shx": "^0.4.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1"
    },
    "main": "./out/extension.js",
    "activationEvents": [],
    "contributes": {
        "configurationDefaults": {
            "[gotmpl]": {
                "editor.wordBasedSuggestions": "off"
            }
        },
        "languages": [
            {
                "id": "gotmpl",
                "aliases": [
                    "Go text/template",
                    "gotmpl"
                ],
                "extensions": [
                    ".tmpl"
                ],
                "icon": {
                    "light": "./icons/icon.svg",
                    "dark": "./icons/icon.svg"
                },
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "gotmpl",
                "scopeName": "source.gotmpl",
                "path": "./syntaxes/gotmpl.tmLanguage.json"
            }
        ],
        "configuration": {
            "title": "text/template Support",
            "properties": {
                "goTmplSupport.enableServer": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable/disable the language server."
                },
                "goTmplSupport.trace.server": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "messages",
                    "description": "Trace communication with the language server."
                }
            }
        },
        "snippets": [
            {
                "language": "gotmpl",
                "path": "snippets/snippets.json"
            }
        ]
    },
    "prettier": {
        "tabWidth": 4
    }
}
