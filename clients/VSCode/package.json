{
    "name": "gotmpls",
    "displayName": "text/template Support",
    "description": "Language support for Go text/template files. See LICENSE and third-party notices in the repository.",
    "version": "1.2.0",
    "license": "MIT",
    "engines": {
        "vscode": "^1.116.0"
    },
    "repository": {
        "url": "https://github.com/allseas/go-template-lsp",
        "directory": "clients/VSCode",
        "type": "git"
    },
    "categories": [
        "Programming Languages"
    ],
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "check-types": "tsc --noEmit",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "lint:fix": "npx eslint . --fix",
        "lint:check": "npx eslint .",
        "format:fix": "npx prettier --write .",
        "format:check": "npx prettier --check .",
        "test:default": "npm run compile && npx ts-node --esm ../../scripts/build-server-binaries.ts && shx mkdir -p out/server/bin && shx cp ../../dist/server/* out/server/bin/ && vscode-test --label default",
        "test:allseas": "npm run compile && npx ts-node --esm ../../scripts/build-server-binaries-allseas.ts && shx mkdir -p out/server/bin && shx cp ../../dist/server/* out/server/bin/ && vscode-test --label allseas",
        "test": "npm run test:default && npm run test:allseas",
        "benchmark": "npm run compile && shx mkdir -p out/server/bin && shx cp ../../dist/server/* out/server/bin/ && vscode-test --label benchmark",
        "benchmark:allseas": "npm run compile && npx ts-node --esm ../../scripts/build-server-binaries-allseas.ts && shx mkdir -p out/server/bin && shx cp ../../dist/server/* out/server/bin/ && vscode-test --label benchmark",
        "verify": "npm run lint:check && npm run format:check && npm test",
        "package": "npm run verify && node esbuild.js --production && vsce package --no-dependencies && shx mv *.vsix ../../",
        "package:no-verify": "node esbuild.js --production && vsce package --no-dependencies && shx mv *.vsix ../../"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1",
        "vscode-oniguruma": "^2.0.1",
        "vscode-textmate": "^9.3.2"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "@types/vscode": "^1.116.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.9.1",
        "esbuild": "^0.28.0",
        "eslint": "^10.2.1",
        "shx": "^0.4.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1"
    },
    "main": "./out/extension.js",
    "activationEvents": [],
    "contributes": {
        "configurationDefaults": {
            "[gotmpl]": {
                "editor.wordBasedSuggestions": "off"
            },
            "[gotmpl-sql]": {
                "editor.wordBasedSuggestions": "off"
            },
            "[gotmpl-html]": {
                "editor.wordBasedSuggestions": "off"
            },
            "[gotmpl-json]": {
                "editor.wordBasedSuggestions": "off"
            },
            "[gotmpl-yaml]": {
                "editor.wordBasedSuggestions": "off"
            },
            "[gotmpl-css]": {
                "editor.wordBasedSuggestions": "off"
            },
            "[gotmpl-js]": {
                "editor.wordBasedSuggestions": "off"
            },
            "[gotmpl-xml]": {
                "editor.wordBasedSuggestions": "off"
            },
            "[gotmpl-md]": {
                "editor.wordBasedSuggestions": "off"
            },
            "[gotmpl-sh]": {
                "editor.wordBasedSuggestions": "off"
            },
            "[gotmpl-scl]": {
                "editor.wordBasedSuggestions": "off"
            },
            "[gotmpl-cpp]": {
                "editor.wordBasedSuggestions": "off"
            }
        },
        "languages": [
            {
                "id": "gotmpl",
                "aliases": [
                    "Go text/template",
                    "gotmpl"
                ],
                "extensions": [
                    ".tmpl"
                ],
                "icon": {
                    "light": "./icons/icon.svg",
                    "dark": "./icons/icon.svg"
                },
                "configuration": "./language-configuration.json"
            },
            {
                "id": "gotmpl-sql",
                "aliases": [
                    "Go text/template (SQL)"
                ],
                "extensions": [
                    ".sql.tmpl",
                    ".sql.gotmpl"
                ],
                "icon": {
                    "light": "./icons/icon.svg",
                    "dark": "./icons/icon.svg"
                },
                "configuration": "./language-configuration.json"
            },
            {
                "id": "gotmpl-html",
                "aliases": [
                    "Go text/template (HTML)"
                ],
                "extensions": [
                    ".html.tmpl",
                    ".html.gotmpl"
                ],
                "icon": {
                    "light": "./icons/icon.svg",
                    "dark": "./icons/icon.svg"
                },
                "configuration": "./language-configuration.json"
            },
            {
                "id": "gotmpl-json",
                "aliases": [
                    "Go text/template (JSON)"
                ],
                "extensions": [
                    ".json.tmpl",
                    ".json.gotmpl"
                ],
                "icon": {
                    "light": "./icons/icon.svg",
                    "dark": "./icons/icon.svg"
                },
                "configuration": "./language-configuration.json"
            },
            {
                "id": "gotmpl-yaml",
                "aliases": [
                    "Go text/template (YAML)"
                ],
                "extensions": [
                    ".yaml.tmpl",
                    ".yaml.gotmpl",
                    ".yml.tmpl",
                    ".yml.gotmpl"
                ],
                "icon": {
                    "light": "./icons/icon.svg",
                    "dark": "./icons/icon.svg"
                },
                "configuration": "./language-configuration.json"
            },
            {
                "id": "gotmpl-css",
                "aliases": [
                    "Go text/template (CSS)"
                ],
                "extensions": [
                    ".css.tmpl",
                    ".css.gotmpl"
                ],
                "icon": {
                    "light": "./icons/icon.svg",
                    "dark": "./icons/icon.svg"
                },
                "configuration": "./language-configuration.json"
            },
            {
                "id": "gotmpl-js",
                "aliases": [
                    "Go text/template (JavaScript)"
                ],
                "extensions": [
                    ".js.tmpl",
                    ".js.gotmpl"
                ],
                "icon": {
                    "light": "./icons/icon.svg",
                    "dark": "./icons/icon.svg"
                },
                "configuration": "./language-configuration.json"
            },
            {
                "id": "gotmpl-xml",
                "aliases": [
                    "Go text/template (XML)"
                ],
                "extensions": [
                    ".xml.tmpl",
                    ".xml.gotmpl"
                ],
                "icon": {
                    "light": "./icons/icon.svg",
                    "dark": "./icons/icon.svg"
                },
                "configuration": "./language-configuration.json"
            },
            {
                "id": "gotmpl-md",
                "aliases": [
                    "Go text/template (Markdown)"
                ],
                "extensions": [
                    ".md.tmpl",
                    ".md.gotmpl"
                ],
                "icon": {
                    "light": "./icons/icon.svg",
                    "dark": "./icons/icon.svg"
                },
                "configuration": "./language-configuration.json"
            },
            {
                "id": "gotmpl-sh",
                "aliases": [
                    "Go text/template (Shell)"
                ],
                "extensions": [
                    ".sh.tmpl",
                    ".sh.gotmpl"
                ],
                "icon": {
                    "light": "./icons/icon.svg",
                    "dark": "./icons/icon.svg"
                },
                "configuration": "./language-configuration.json"
            },
            {
                "id": "gotmpl-scl",
                "aliases": [
                    "Go text/template (SCL)"
                ],
                "extensions": [
                    ".scl.tmpl",
                    ".scl.gotmpl"
                ],
                "icon": {
                    "light": "./icons/icon.svg",
                    "dark": "./icons/icon.svg"
                },
                "configuration": "./language-configuration.json"
            },
            {
                "id": "gotmpl-cpp",
                "aliases": [
                    "Go text/template (C++)"
                ],
                "extensions": [
                    ".cpp.tmpl",
                    ".cpp.gotmpl"
                ],
                "icon": {
                    "light": "./icons/icon.svg",
                    "dark": "./icons/icon.svg"
                },
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "gotmpl",
                "scopeName": "source.gotmpl",
                "path": "./syntaxes/gotmpl.tmLanguage.json"
            },
            {
                "language": "gotmpl-sql",
                "scopeName": "source.gotmpl.sql",
                "path": "./syntaxes/gotmpl-sql.tmLanguage.json"
            },
            {
                "language": "gotmpl-html",
                "scopeName": "source.gotmpl.html",
                "path": "./syntaxes/gotmpl-html.tmLanguage.json"
            },
            {
                "language": "gotmpl-json",
                "scopeName": "source.gotmpl.json",
                "path": "./syntaxes/gotmpl-json.tmLanguage.json"
            },
            {
                "language": "gotmpl-yaml",
                "scopeName": "source.gotmpl.yaml",
                "path": "./syntaxes/gotmpl-yaml.tmLanguage.json"
            },
            {
                "language": "gotmpl-css",
                "scopeName": "source.gotmpl.css",
                "path": "./syntaxes/gotmpl-css.tmLanguage.json"
            },
            {
                "language": "gotmpl-js",
                "scopeName": "source.gotmpl.js",
                "path": "./syntaxes/gotmpl-js.tmLanguage.json"
            },
            {
                "language": "gotmpl-xml",
                "scopeName": "source.gotmpl.xml",
                "path": "./syntaxes/gotmpl-xml.tmLanguage.json"
            },
            {
                "language": "gotmpl-md",
                "scopeName": "source.gotmpl.md",
                "path": "./syntaxes/gotmpl-md.tmLanguage.json"
            },
            {
                "language": "gotmpl-sh",
                "scopeName": "source.gotmpl.sh",
                "path": "./syntaxes/gotmpl-sh.tmLanguage.json"
            },
            {
                "language": "gotmpl-scl",
                "scopeName": "source.gotmpl.scl",
                "path": "./syntaxes/gotmpl-scl.tmLanguage.json"
            },
            {
                "language": "gotmpl-cpp",
                "scopeName": "source.gotmpl.cpp",
                "path": "./syntaxes/gotmpl-cpp.tmLanguage.json"
            }
        ],
        "configuration": {
            "title": "text/template Support",
            "properties": {
                "goTmplSupport.enableHover": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable/disable hover information."
                },
                "goTmplSupport.enableDefinition": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable/disable go-to-definition."
                },
                "goTmplSupport.enableDiagnostics": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable/disable all diagnostics."
                },
                "goTmplSupport.diagnostics": {
                    "type": "object",
                    "default": {
                        "invalidField": "error",
                        "invalidFunction": "warning",
                        "invalidCommand": "error",
                        "invalidRange": "error",
                        "invalidWith": "error",
                        "undeclaredVariable": "error",
                        "doubleDeclaredVariable": "warning",
                        "invalidTemplateArg": "error",
                        "argumentNumberMismatch": "error",
                        "unknownType": "information",
                        "syntaxError": "error",
                        "hintLoadFailure": "warning",
                        "unknownRangeType": "warning",
                        "emptyDefineName": "warning",
                        "variableReassigned": "warning",
                        "malformedHint": "error",
                        "invalidDictKey": "information",
                        "conflictingHint": "warning"
                    },
                    "additionalProperties": {
                        "type": "string",
                        "enum": [
                            "disabled",
                            "error",
                            "warning",
                            "information",
                            "hint"
                        ]
                    },
                    "description": "Per-diagnostic severity levels. Valid values: \"disabled\", \"error\", \"warning\", \"information\", \"hint\"."
                },
                "goTmplSupport.enableAutocompletion": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable/disable autocompletion."
                },
                "goTmplSupport.pipeChainCompletion": {
                    "type": "string",
                    "enum": [
                        "off",
                        "full",
                        "step"
                    ],
                    "default": "step",
                    "description": "Change nested field configuration"
                },
                "goTmplSupport.trace.server": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "messages",
                    "description": "Trace communication with the language server."
                }
            }
        },
        "snippets": [
            {
                "language": "gotmpl",
                "path": "snippets/snippets.json"
            },
            {
                "language": "gotmpl-sql",
                "path": "snippets/snippets.json"
            },
            {
                "language": "gotmpl-html",
                "path": "snippets/snippets.json"
            },
            {
                "language": "gotmpl-json",
                "path": "snippets/snippets.json"
            },
            {
                "language": "gotmpl-yaml",
                "path": "snippets/snippets.json"
            },
            {
                "language": "gotmpl-css",
                "path": "snippets/snippets.json"
            },
            {
                "language": "gotmpl-js",
                "path": "snippets/snippets.json"
            },
            {
                "language": "gotmpl-xml",
                "path": "snippets/snippets.json"
            },
            {
                "language": "gotmpl-md",
                "path": "snippets/snippets.json"
            },
            {
                "language": "gotmpl-sh",
                "path": "snippets/snippets.json"
            },
            {
                "language": "gotmpl-scl",
                "path": "snippets/snippets.json"
            },
            {
                "language": "gotmpl-cpp",
                "path": "snippets/snippets.json"
            }
        ]
    },
    "prettier": {
        "tabWidth": 4
    }
}
