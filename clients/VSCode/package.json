{
    "name": "text-template-support",
    "displayName": "text/template Support",
    "description": "",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.116.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "check-types": "tsc --noEmit",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "vscode:prepublish": "npm run package",
        "package": "npm run check-types && node esbuild.js --production",
        "lint:fix": "npx eslint . --fix",
        "lint:check": "npx eslint .",
        "format": "npx prettier --write .",
        "format:check": "npx prettier --check .",
        "test": "vscode-test"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "@types/vscode": "^1.116.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "esbuild": "^0.28.0",
        "eslint": "^10.2.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1"
    },
    "main": "out/extension.js",
    "activationEvents": [],
    "contributes": {
        "languages": [
            {
                "id": "gotmpl",
                "aliases": [
                    "Go text/template",
                    "gotmpl"
                ],
                "extensions": [
                    ".tmpl"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "gotmpl",
                "scopeName": "source.gotmpl",
                "path": "./syntaxes/gotmpl.tmLanguage.json"
            }
        ],
        "configuration": {
            "title": "text/template Support",
            "properties": {
                "goTmplSupport.enableServer": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable/disable the language server."
                },
                "goTmplSupport.trace.server": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "messages",
                    "description": "Trace communication with the language server."
                }
            }
        },

        "snippets": [
            {
                "language": "gotmpl",
                "path": "snippets/snippets.json"
            }
        ]
    },
    "prettier": {
        "tabWidth": 4
    }
}
