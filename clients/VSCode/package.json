{
    "name": "text-template-support",
    "displayName": "text/template Support",
    "description": "Language support for Go text/template files. See LICENSE and third-party notices in the repository.",
    "version": "1.1.0",
    "engines": {
        "vscode": "^1.116.0"
    },
    "repository": {
        "url": "",
        "directory": "",
        "type": ""
    },
    "categories": [
        "Programming Languages"
    ],
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "check-types": "tsc --noEmit",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "lint:fix": "npx eslint . --fix",
        "lint:check": "npx eslint .",
        "format:fix": "npx prettier --write .",
        "format:check": "npx prettier --check .",
        "test:default": "npm run compile && ts-node --esm ../../scripts/build-server-binaries.ts && shx mkdir -p out/server/bin && shx cp ../../dist/server/* out/server/bin/ && vscode-test --label default",
        "test:allseas": "npm run compile && ts-node --esm ../../scripts/build-server-binaries-allseas.ts && shx mkdir -p out/server/bin && shx cp ../../dist/server/* out/server/bin/ && vscode-test --label allseas",
        "test": "npm run test:default && npm run test:allseas",
        "benchmark": "npm run compile && shx mkdir -p out/server/bin && shx cp ../../dist/server/* out/server/bin/ && vscode-test --label benchmark",
        "benchmark:allseas": "npm run compile && ts-node --esm ../../scripts/build-server-binaries-allseas.ts && shx mkdir -p out/server/bin && shx cp ../../dist/server/* out/server/bin/ && vscode-test --label benchmark",
        "verify": "npm run lint:check && npm run format:check && npm test",
        "package": "npm run verify && node esbuild.js --production && vsce package --no-dependencies && shx mv *.vsix ../../",
        "package:no-verify": "node esbuild.js --production && vsce package --no-dependencies && shx mv *.vsix ../../"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1",
        "vscode-oniguruma": "^2.0.1",
        "vscode-textmate": "^9.3.2"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "@types/vscode": "^1.116.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.9.1",
        "esbuild": "^0.28.0",
        "eslint": "^10.2.1",
        "shx": "^0.4.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1"
    },
    "main": "./out/extension.js",
    "activationEvents": [],
    "contributes": {
        "configurationDefaults": {
            "[gotmpl]": {
                "editor.wordBasedSuggestions": "off"
            }
        },
        "languages": [
            {
                "id": "gotmpl",
                "aliases": [
                    "Go text/template",
                    "gotmpl"
                ],
                "extensions": [
                    ".tmpl"
                ],
                "icon": {
                    "light": "./icons/icon.svg",
                    "dark": "./icons/icon.svg"
                },
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "gotmpl",
                "scopeName": "source.gotmpl",
                "path": "./syntaxes/gotmpl.tmLanguage.json"
            }
        ],
        "configuration": {
            "title": "text/template Support",
            "properties": {
                "goTmplSupport.enableHover": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable/disable hover information."
                },
                "goTmplSupport.enableDefinition": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable/disable go-to-definition."
                },
                "goTmplSupport.enableDiagnostics": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable/disable all diagnostics."
                },
                "goTmplSupport.diagnostics": {
                    "type": "object",
                    "default": {
                        "invalidField": "error",
                        "invalidFunction": "warning",
                        "invalidCommand": "error",
                        "invalidRange": "error",
                        "invalidWith": "error",
                        "undeclaredVariable": "error",
                        "doubleDeclaredVariable": "warning",
                        "invalidTemplateArg": "error",
                        "argumentNumberMismatch": "error",
                        "unknownType": "information",
                        "syntaxError": "error",
                        "hintLoadFailure": "warning",
                        "unknownRangeType": "warning",
                        "emptyDefineName": "warning"
                    },
                    "additionalProperties": {
                        "type": "string",
                        "enum": [
                            "disabled",
                            "error",
                            "warning",
                            "information",
                            "hint"
                        ]
                    },
                    "description": "Per-diagnostic severity levels. Valid values: \"disabled\", \"error\", \"warning\", \"information\", \"hint\"."
                },
                "goTmplSupport.enableAutocompletion": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable/disable autocompletion."
                },
                "goTmplSupport.pipeChainCompletion": {
                    "type": "string",
                    "enum": [
                        "off",
                        "full",
                        "step"
                    ],
                    "default": "step",
                    "description": "Change nested field configuration"
                },
                "goTmplSupport.trace.server": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "messages",
                    "description": "Trace communication with the language server."
                }
            }
        },
        "snippets": [
            {
                "language": "gotmpl",
                "path": "snippets/snippets.json"
            }
        ]
    },
    "prettier": {
        "tabWidth": 4
    }
}
