{{ $n := nil }}            {{/* hover $n -> var $n nil     */}}
{{/* -------- 2. Variables initialised from . fields (OK) -------- */}}
{{ $id     := .ID }}              {{/* string                       */}}
{{ $name   := .CustomerName }}    {{/* string                       */}}
{{ $email  := .Email }}           {{/* string                       */}}
{{ $items  := .Items }}           {{/* []model.Item                 */}}
{{ $addr   := .Address }}         {{/* model.Address                */}}
{{ $street := .Address.Street }}  {{/* string                       */}}
{{ $total  := .TotalAmount }}     {{/* float64                      */}}
{{ $paid   := .Paid }}            {{/* bool                         */}}
{{/* -------- 3. Variables initialised from methods (OK) -------- */}}
{{ $disp  := .DisplayName }}      {{/* string  (Order.DisplayName)  */}}
{{ $count := .ItemCount }}        {{/* int     (Order.ItemCount)    */}}
{{ $big   := .IsLargeOrder }}     {{/* bool    (Order.IsLargeOrder) */}}
{{/* -------- 4. Range: index + element variables (OK) -------- */}}
{{ range $idx, $it := .Items }}
  {{/* $idx -> var $idx uint     */}}
  {{/* $it  -> var $it  model.Item */}}
  {{ $sku  := $it.SKU }}          {{/* string  */}}
  {{ $qty  := $it.Qty }}          {{/* int     */}}
  {{ $unit := $it.UnitPrice }}    {{/* float64 */}}
  {{ $lbl  := $it.Label }}        {{/* string  (Item.Label)  */}}
  {{ $tot  := $it.Total }}        {{/* float64 (Item.Total)  */}}
{{ end }}
{{/* -------- 5. With: dot rebinding (partial OK) -------- */}}
{{ with .Address }}
  {{ $h := . }}                   {{/* TODO DotNode -> would be model.Address */}}
