{{ repeat    "ab" 3 }}                   {{/* hover `repeat`    */}}
{{ kebabCase "Hello World" }}            {{/* hover `kebabCase` */}}
{{ sprintf   "id=%s" .ID }}              {{/* hover `sprintf`   */}}
{{ shout     "wow" }}                    {{/* hover `shout`     */}}

