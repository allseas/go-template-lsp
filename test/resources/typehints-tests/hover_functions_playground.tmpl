{{/* -------- 1. Built-in actions / keywords -------- */}}
{{ if .Paid }}paid{{ else if .IsLargeOrder }}big{{ else }}unpaid{{ end }}
{{ range .Items }}{{ .Name }}{{ end }}
{{ with .Address }}{{ .City }}{{ end }}
{{ define "greeting" }}hi {{ . }}{{ end }}
{{ template "greeting" .CustomerName }}
{{ block "footer" . }}-- end --{{ end }}

{{/* -------- 2. Built-in functions -------- */}}
{{ and .Paid .IsLargeOrder }}            {{/* hover `and`  */}}
{{ or  .Paid .IsLargeOrder }}            {{/* hover `or`   */}}
{{ not .Paid }}                          {{/* hover `not`  */}}
{{ len .Items }}                         {{/* hover `len`  */}}
{{ len .CustomerName }}                  {{/* hover `len` on string */}}
{{ index .Items 0 }}                     {{/* hover `index` */}}
{{ slice .Items 0 2 }}                   {{/* hover `slice` */}}
{{ slice .CustomerName 0 3 }}            {{/* hover `slice` on string */}}

{{/* -------- 3. Built-in formatting funcs -------- */}}
{{ print   "a" "b" "c" }}                {{/* hover `print`   */}}
{{ printf  "%s = %d" .ID .ItemCount }}   {{/* hover `printf`  */}}
{{ println "line" }}                     {{/* hover `println` */}}

{{/* -------- 4. Built-in escapers -------- */}}
{{ html      .CustomerName }}            {{/* hover `html`     */}}
{{ js        .CustomerName }}            {{/* hover `js`       */}}
{{ urlquery  .CustomerName }}            {{/* hover `urlquery` */}}

{{/* -------- 5. Built-in comparison funcs -------- */}}
{{ eq .Paid true }}                      {{/* hover `eq` */}}
{{ ne .ID  "" }}                         {{/* hover `ne` */}}
{{ lt .TotalAmount 100.0 }}              {{/* hover `lt` */}}
{{ le .TotalAmount 100.0 }}              {{/* hover `le` */}}
{{ gt .TotalAmount 100.0 }}              {{/* hover `gt` */}}
{{ ge .TotalAmount 100.0 }}              {{/* hover `ge` */}}

{{/* -------- 6. `call` built-in (invoke a function value) -------- */}}
{{ $fn := .DisplayName }}                {{/* method value */}}
{{ call .DisplayName }}                  {{/* hover `call` */}}

