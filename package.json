{
  "name": "go-template-extensions",
  "version": "1.0.0",
  "description": "",
  "private": "true",
  "directories": {
    "doc": "docs"
  },
  "workspaces": ["clients/*", "scripts"],
  "scripts": {
    "generate:syntax": "ts-node --esm scripts/generate-syntax.ts",
    "build:server": "ts-node --esm scripts/build-server-binaries.ts",
    "build:server:vscode": "ts-node --esm scripts/build-server-binaries.ts --vscode",
    "build:vscode": "npm run build:server:vscode && npm run compile -w clients/VSCode",
    "package:vscode": "npm run build:server:vscode && npm run package:no-verify -w clients/VSCode",
    "watch:vscode": "(ts-node --esm scripts/watch-server-binaries.ts) | (npm run watch -w clients/VSCode)",
    "launch:vscode": "npm run package:vscode && find . | grep '.vsix' | xargs -i code --install-extension {} && code ./test"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.8.0",
    "npm": ">=11.6.0"
  }
}
